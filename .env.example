
# LLM
OPENAI_API_KEY=sk-your-key-here

# LangSmith tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls-your-key-here
LANGCHAIN_PROJECT=ecomsense

# PostgreSQL — get free DB URL from neon.tech
DATABASE_URL=postgresql+psycopg://user:pass@host/dbname

# Redis — get free URL from upstash.com
UPSTASH_REDIS_URL=rediss://your-upstash-url
UPSTASH_REDIS_PASSWORD=your-password

# Slack (optional for now)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# App
ENVIRONMENT=development
EOF

